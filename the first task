        "import matplotlib.pyplot as plt\n",
        "\n",
        "# 1. Group the data by Year and Quarter\n",
        "df['Year'] = df['Order_Date'].dt.year\n",
        "df['Quarter'] = df['Order_Date'].dt.quarter\n",
        "q_sales = df.groupby(['Year', 'Quarter'])['Total_Sales'].sum().reset_index()\n",
        "\n",
        "# 2. Create a clean label for the timeline (like \"2023-Q1\")\n",
        "q_sales['Period'] = q_sales['Year'].astype(str) + '-Q' + q_sales['Quarter'].astype(str)\n",
        "\n",
        "# 3. Draw a standard line graph\n",
        "plt.figure(figsize=(10, 5))\n",
        "plt.plot(q_sales['Period'], q_sales['Total_Sales'], marker='o', color='green', linewidth=2)\n",
        "plt.title('Quarterly Revenue Growth')\n",
        "plt.xlabel('Time Period')\n",
        "plt.ylabel('Total Sales')\n",
        "plt.xticks(rotation=45)\n",
        "plt.grid(True)\n",
        "plt.show()"
